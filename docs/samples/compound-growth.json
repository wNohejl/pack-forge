{
  "name": "compound-growth",
  "parameters": {
    "principal": 10000,
    "rate": 0.07,
    "years": 30,
    "monthlyContribution": 500
  },
  "expressions": [
    { "name": "growthFactor", "formula": "(1 + rate) ^ years" },
    { "name": "lumpSumValue", "formula": "principal * growthFactor" },
    { "name": "contributionValue", "formula": "monthlyContribution * 12 * ((growthFactor - 1) / rate)" },
    { "name": "totalValue", "formula": "lumpSumValue + contributionValue" },
    { "name": "totalContributed", "formula": "principal + monthlyContribution * 12 * years" },
    { "name": "totalGrowth", "formula": "totalValue - totalContributed" }
  ]
}
