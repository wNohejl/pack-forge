@page "/migration"
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using PackForge.Web.Realtime
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>PackForge — Migration</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Migration</MudText>
<MudText Class="mb-4">Strangler backfill from the legacy file share and SharePoint into blob storage. Every file is checksum-verified before the source copy is trusted; unverified files keep serving from the legacy source via dual-read. Progress streams live over SignalR.</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudSync"
           OnClick="RunAsync" Disabled="@(report?.Running == true)" Class="mb-4">
    @(report?.Running == true ? "Running…" : "Scan & migrate")
</MudButton>

@if (report is not null)
{
    @if (report.Running)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
    }
    <MudText Class="mb-3">
        Copied <b>@FormatSize(report.BytesCopied)</b>
        @(report.ThroughputMBps > 0 ? $" at {report.ThroughputMBps:F1} MB/s" : "")
        @(report.FinishedAt is not null ? " — run complete." : report.Running ? " — in progress…" : "")
    </MudText>

    <MudDataGrid T="StatusRow" Items="report.ByStatus" Dense="true" Hover="true" Elevation="1" SortMode="SortMode.Multiple" Class="mb-4">
        <Columns>
            <PropertyColumn Property="r => r.SourceSystem" Title="Source" />
            <TemplateColumn Title="Status" SortBy="r => r.Status">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)">@context.Item.Status</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="r => r.Count" Title="Files" />
            <TemplateColumn Title="Bytes" SortBy="r => r.Bytes">
                <CellTemplate>@FormatSize(context.Item.Bytes)</CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>

    @if (report.Failures.Count > 0)
    {
        <MudExpansionPanels Elevation="1" Class="mb-4">
            <MudExpansionPanel Text="@($"Failures ({report.Failures.Count} shown)")">
                <MudList T="string" Dense="true">
                    @foreach (var f in report.Failures)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Error">
                            <code>@f.SourceSystem/@f.SourcePath</code> — @f.Error
                        </MudListItem>
                    }
                </MudList>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
}

<MudDivider Class="my-4" />
<div class="d-flex align-center gap-3 mb-2">
    <MudText Typo="Typo.h6">Reconciliation report</MudText>
    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="LoadReconciliationAsync">Run stored procedure</MudButton>
    @if (reconciliation is not null)
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Info">@reconciliation.Provider</MudChip>
    }
</div>
<MudText Typo="Typo.body2" Class="mb-2">Computed in the database by a stored procedure (SQL Server) / function (PostgreSQL), invoked via EF Core.</MudText>
@if (reconciliation is not null)
{
    <MudDataGrid T="ReconRow" Items="reconciliation.Rows" Dense="true" Hover="true" Elevation="1">
        <Columns>
            <PropertyColumn Property="r => r.SourceSystem" Title="Source" />
            <PropertyColumn Property="r => r.TotalFiles" Title="Total" />
            <PropertyColumn Property="r => r.VerifiedFiles" Title="Verified" />
            <PropertyColumn Property="r => r.FailedFiles" Title="Failed" />
            <TemplateColumn Title="Verified bytes">
                <CellTemplate>@FormatSize(context.Item.VerifiedBytes)</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Verification rate">
                <CellTemplate>@($"{context.Item.VerificationRate:P1}")</CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    private Report? report;
    private ReconReport? reconciliation;
    private HubConnection? hub;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/progress"))
            .WithAutomaticReconnect()
            .Build();
        hub.On(ProgressHub.MigrationChanged, async () =>
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        });
        await hub.StartAsync();
    }

    private HttpClient Client()
    {
        var http = HttpFactory.CreateClient();
        http.BaseAddress = new Uri(Nav.BaseUri);
        return http;
    }

    private async Task RefreshAsync()
    {
        using var http = Client();
        report = await http.GetFromJsonAsync<Report>("/api/migration/report");
    }

    private async Task RunAsync()
    {
        using var http = Client();
        await http.PostAsync("/api/migration/run", null);
        await RefreshAsync();
    }

    private async Task LoadReconciliationAsync()
    {
        using var http = Client();
        reconciliation = await http.GetFromJsonAsync<ReconReport>("/api/migration/reconciliation");
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        >= 1 << 30 => $"{bytes / (double)(1 << 30):F2} GB",
        >= 1 << 20 => $"{bytes / (double)(1 << 20):F1} MB",
        >= 1 << 10 => $"{bytes / (double)(1 << 10):F1} KB",
        _ => $"{bytes} B",
    };

    private static Color StatusColor(string status) => status switch
    {
        "Verified" => Color.Success,
        "Failed" => Color.Error,
        "Copied" => Color.Info,
        _ => Color.Default,
    };

    private record Report(bool Running, DateTimeOffset? StartedAt, DateTimeOffset? FinishedAt, long BytesCopied,
        double ThroughputMBps, List<StatusRow> ByStatus, List<Failure> Failures);

    private record StatusRow(string SourceSystem, string Status, int Count, long Bytes);

    private record Failure(string SourceSystem, string SourcePath, string? Error);

    private record ReconReport(string Provider, List<ReconRow> Rows);

    private record ReconRow(string SourceSystem, int TotalFiles, int VerifiedFiles, int FailedFiles,
        int PendingFiles, long TotalBytes, long VerifiedBytes, double VerificationRate);

    public async ValueTask DisposeAsync()
    {
        if (hub is not null)
            await hub.DisposeAsync();
    }
}
