@page "/"
@using Microsoft.EntityFrameworkCore
@using PackForge.Core
@using PackForge.Web.Data
@inject IDbContextFactory<PackForgeDbContext> DbFactory
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>PackForge — Uploads</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Uploads</MudText>
<MudText Class="mb-4">Upload a model file — it goes browser → blob storage directly via SAS; the server only records metadata and verifies the checksum.</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <div class="d-flex gap-4 align-center flex-wrap">
        <InputFile @ref="fileInput" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload"
                   OnClick="UploadAsync" Disabled="@uploading">Upload</MudButton>
    </div>
    @if (uploading)
    {
        <MudProgressLinear Color="Color.Primary" Value="@progress" Class="mt-3" />
        <MudText Typo="Typo.caption">@progress%</MudText>
    }
    @if (error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@error</MudAlert>
    }
</MudPaper>

<MudDataGrid T="Upload" Items="uploads" Filterable="true" SortMode="SortMode.Multiple" Dense="true" Hover="true" Elevation="1">
    <Columns>
        <PropertyColumn Property="u => u.FileName" Title="File" />
        <TemplateColumn Title="Size" SortBy="u => u.SizeBytes">
            <CellTemplate>@FormatSize(context.Item.SizeBytes)</CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="SHA-256" Sortable="false">
            <CellTemplate><code>@(context.Item.Sha256 is null ? "—" : context.Item.Sha256[..12] + "…")</code></CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="u => u.Status" Title="Status" />
        <PropertyColumn Property="u => u.CreatedAt.LocalDateTime" Title="Uploaded" Format="g" />
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
            <CellTemplate>
                @if (context.Item.Status == UploadStatus.Ready)
                {
                    <MudLink Href="@($"/api/uploads/{context.Item.Id}/download")" Target="_blank">download</MudLink>
                }
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private InputFile? fileInput;
    private List<Upload> uploads = [];
    private bool uploading;
    private int progress;
    private string? error;
    private DotNetObjectReference<Home>? selfRef;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        uploads = await db.Uploads.OrderByDescending(u => u.CreatedAt).Take(100).ToListAsync();
    }

    private async Task UploadAsync()
    {
        error = null;
        uploading = true;
        progress = 0;
        selfRef ??= DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeAsync<object>("packforge.upload", fileInput!.Element, selfRef);
        }
        catch (JSException ex)
        {
            error = ex.Message;
        }
        finally
        {
            uploading = false;
            await RefreshAsync();
        }
    }

    [JSInvokable]
    public Task OnProgress(int percent)
    {
        progress = percent;
        return InvokeAsync(StateHasChanged);
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        >= 1 << 30 => $"{bytes / (double)(1 << 30):F1} GB",
        >= 1 << 20 => $"{bytes / (double)(1 << 20):F1} MB",
        >= 1 << 10 => $"{bytes / (double)(1 << 10):F1} KB",
        _ => $"{bytes} B",
    };

    public void Dispose() => selfRef?.Dispose();
}
