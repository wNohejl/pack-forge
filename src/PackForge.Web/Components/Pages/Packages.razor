@page "/packages"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@using PackForge.Core
@using PackForge.Web.Data
@using PackForge.Web.Realtime
@inject IDbContextFactory<PackForgeDbContext> DbFactory
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>PackForge — Packages</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Packages</MudText>
<MudText Class="mb-4">Pick an uploaded model definition (.json) and build a versioned deployment package. Builds run asynchronously off the storage queue and update live over SignalR.</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <div class="d-flex gap-4 align-center flex-wrap">
        <MudSelect T="string" @bind-Value="selectedUploadId" Label="Ready model upload" Variant="Variant.Outlined"
                   Dense="true" Style="min-width: 320px;">
            @foreach (var u in modelUploads)
            {
                <MudSelectItem Value="@u.Id.ToString()">@u.FileName (@u.CreatedAt.ToLocalTime().ToString("g"))</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Build"
                   OnClick="BuildAsync" Disabled="@string.IsNullOrEmpty(selectedUploadId)">Build package</MudButton>
    </div>
    @if (message is not null)
    {
        <MudAlert Severity="@(validationErrors.Count > 0 ? Severity.Error : Severity.Info)" Class="mt-3" Dense="true">@message</MudAlert>
    }
    @if (validationErrors.Count > 0)
    {
        <MudList T="string" Dense="true">
            @foreach (var e in validationErrors)
            {
                <MudListItem T="string" Icon="@Icons.Material.Filled.Error"><b>@e.Key:</b> @string.Join("; ", e.Value)</MudListItem>
            }
        </MudList>
    }
</MudPaper>

<MudDataGrid T="PackageBuild" Items="builds" Filterable="true" SortMode="SortMode.Multiple" Dense="true" Hover="true" Elevation="1">
    <Columns>
        <PropertyColumn Property="b => b.ModelName" Title="Model" />
        <PropertyColumn Property="b => b.Version" Title="Version" />
        <TemplateColumn Title="Status" Sortable="true" SortBy="b => b.Status">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)">@context.Item.Status</MudChip>
                @if (context.Item.Error is not null)
                {
                    <MudTooltip Text="@context.Item.Error"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" /></MudTooltip>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Package SHA-256" Sortable="false">
            <CellTemplate>
                <code>@(context.Item.PackageSha256 is null ? "—" : context.Item.PackageSha256[..12] + "…")</code>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="b => b.CreatedAt.LocalDateTime" Title="Created" Format="g" />
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
            <CellTemplate>
                @if (context.Item.Status == BuildStatus.Ready)
                {
                    <MudLink Href="@($"/api/packages/{context.Item.Id}/download")" Target="_blank">download</MudLink>
                    @if (context.Item.Published)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">published</MudChip>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary"
                                   OnClick="@(() => PublishAsync(context.Item.Id))">publish</MudButton>
                    }
                }
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<Upload> modelUploads = [];
    private List<PackageBuild> builds = [];
    private string? selectedUploadId;
    private string? message;
    private Dictionary<string, string[]> validationErrors = [];
    private HubConnection? hub;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();

        // Live updates over SignalR (WebSockets) — the server pushes when a build
        // changes state, replacing the old poll-every-2s timer.
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/progress"))
            .WithAutomaticReconnect()
            .Build();
        hub.On(ProgressHub.BuildsChanged, async () =>
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        });
        await hub.StartAsync();
    }

    private async Task RefreshAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        modelUploads = await db.Uploads
            .Where(u => u.Status == UploadStatus.Ready && u.FileName.EndsWith(".json"))
            .OrderByDescending(u => u.CreatedAt).Take(50).ToListAsync();
        builds = await db.PackageBuilds.OrderByDescending(b => b.CreatedAt).Take(100).ToListAsync();
    }

    private async Task BuildAsync()
    {
        message = null;
        validationErrors = [];
        using var http = HttpFactory.CreateClient();
        http.BaseAddress = new Uri(Nav.BaseUri);
        var resp = await http.PostAsJsonAsync("/api/packages", new { uploadId = selectedUploadId });
        if (resp.IsSuccessStatusCode)
        {
            var result = await resp.Content.ReadFromJsonAsync<BuildResponse>();
            message = result!.Reused
                ? $"Identical model content — reusing existing package v{result.Version}."
                : $"Queued build v{result.Version}.";
        }
        else if (resp.StatusCode == System.Net.HttpStatusCode.BadRequest && resp.Content.Headers.ContentType?.MediaType == "application/problem+json")
        {
            var problem = await resp.Content.ReadFromJsonAsync<ValidationProblem>();
            validationErrors = problem?.Errors ?? [];
            message = "Model failed validation:";
        }
        else
        {
            message = await resp.Content.ReadAsStringAsync();
        }
        await RefreshAsync();
    }

    private async Task PublishAsync(Guid id)
    {
        message = null;
        using var http = HttpFactory.CreateClient();
        http.BaseAddress = new Uri(Nav.BaseUri);
        var resp = await http.PostAsync($"/api/packages/{id}/publish", null);
        message = resp.IsSuccessStatusCode ? "Package published — release gate passed." : await resp.Content.ReadAsStringAsync();
        await RefreshAsync();
    }

    private static Color StatusColor(BuildStatus status) => status switch
    {
        BuildStatus.Ready => Color.Success,
        BuildStatus.Failed => Color.Error,
        BuildStatus.Building => Color.Info,
        _ => Color.Default,
    };

    private record BuildResponse(Guid Id, int Version, bool Reused);

    private record ValidationProblem(Dictionary<string, string[]> Errors);

    public async ValueTask DisposeAsync()
    {
        if (hub is not null)
            await hub.DisposeAsync();
    }
}
